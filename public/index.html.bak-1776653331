<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>联想乐享AI-联想官方AI助手-懂你所需更方便-企业超级智能体-企业智能体解决方案</title>
<script src="/marked.min.js"></script>
<style>

*{margin:0;padding:0;box-sizing:border-box}
/* ════ LIGHT ════ */
:root,[data-theme="light"]{
  --bg:#F7F5FB;--bg-chat:#ffffff;--text:#1A1A2E;--text2:#666580;--border:#EBE5F2;--card:#F4EFFA;--card2:#fff;
  --accent:#E12521;--primary:#3D0366;--primary-grad:linear-gradient(135deg,#3D0366,#87112b);
  --nav-bg:rgba(255,255,255,.95);--nav-bd:#EBE5F2;
  --search-bg:#ffffff;--search-bd:#DDD5E8;
  --tag-bg:#F4EFFA;--tag-bd:#DDD5E8;
  --hero-bg:#F7F5FB;--hp:rgba(200,180,240,.25);--hb:rgba(135,17,43,.1);--hv:rgba(61,3,102,.12);--hr:rgba(225,37,33,.08);
  --icon-bg:#EBE5F2;--cta-bg:#F4EFFA;--ft-bd:#EBE5F2;
  --btn-bg:#3D0366;--btn-bg2:#2a0248;--btn-c:#fff;
  --tog-bg:#DDD5E8;--tog-knob:#fff;--logo-f:none;
  --send-btn-bg:linear-gradient(135deg,#3D0366,#87112b);
}
/* ════ DARK ════ */
[data-theme="dark"]{
  --bg:#09090d;--text:#e2e2ea;--text2:#666;--border:#1c1c28;--card:#131320;--card2:#18182a;
  --accent:#ff5a50;--nav-bg:rgba(9,9,13,.86);--nav-bd:#1a1a26;
  --search-bg:rgba(25,25,40,.7);--search-bd:rgba(50,50,70,.55);
  --tag-bg:rgba(25,25,40,.55);--tag-bd:rgba(50,50,70,.45);
  --hero-bg:#09090d;--hp:rgba(200,60,100,.18);--hb:rgba(60,120,220,.17);--hv:rgba(140,80,220,.14);--hr:rgba(180,70,100,.12);
  --icon-bg:#1a1a2a;--cta-bg:#131320;--ft-bd:#1a1a26;
  --btn-bg:#e2e2ea;--btn-bg2:#bbb;--btn-c:#09090d;
  --tog-bg:#222230;--tog-knob:#e2e2ea;--logo-f:brightness(0) invert(1);
}
html{scroll-behavior:smooth}
body,nav,.hero-wrap,.pcard,.scard,.ncard,.citem,.cta,footer,.search input,.tag{transition:background .45s ease,color .45s ease,border-color .45s ease}
body{font-family:'Noto Sans SC','Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden}

nav{position:fixed;top:0;left:0;right:0;z-index:100;background:var(--nav-bg);backdrop-filter:blur(20px);border-bottom:1px solid var(--nav-bd);padding:0 40px;height:56px;display:flex;align-items:center;justify-content:space-between;gap:12px}
.logo{flex-shrink:0;display:flex;align-items:center}
.logo img{height:26px;width:auto;object-fit:contain;display:block}
.nlinks{display:flex;gap:20px;flex-shrink:0}
.nlinks a{text-decoration:none;color:var(--text);font-size:13px;opacity:.6;transition:opacity .3s;white-space:nowrap}
.nlinks a:hover{opacity:1}
.nright{display:flex;align-items:center;gap:16px;margin-left:auto;flex-shrink:0}
.nright a{text-decoration:none;font-size:13px;color:var(--text);opacity:.6;white-space:nowrap;transition:opacity .3s}
.nright a:hover{opacity:1}
.nright .sep{color:var(--text);opacity:.25;font-size:13px;user-select:none}
.nav-search{width:20px;height:20px;opacity:.5;cursor:pointer;transition:opacity .3s;flex-shrink:0;color:var(--text)}
.nav-search:hover{opacity:1}

/* TOGGLE */
.tog{position:relative;width:54px;height:28px;background:var(--tog-bg);border-radius:999px;cursor:pointer;border:none;padding:0;transition:background .4s;flex-shrink:0;display:flex;align-items:center}
.tog .k{position:absolute;top:2px;left:2px;width:24px;height:24px;border-radius:50%;background:var(--tog-knob);box-shadow:0 1px 4px rgba(0,0,0,.2);transition:transform .4s cubic-bezier(.4,0,.2,1)}
[data-theme="dark"] .tog .k{transform:translateX(26px)}
.tog svg{position:absolute;width:13px;height:13px;pointer-events:none;transition:opacity .3s}
.tog .sun{left:7px;color:#f59e0b;opacity:1}
.tog .moon{right:7px;color:#818cf8;opacity:.3}
[data-theme="dark"] .tog .sun{opacity:.3}
[data-theme="dark"] .tog .moon{opacity:1}
.btn{background:var(--btn-bg);color:var(--btn-c);border:none;padding:8px 20px;border-radius:999px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .3s}
.btn:hover{background:var(--btn-bg2);transform:translateY(-1px)}

/* HERO */
.hero-wrap{position:relative;overflow:hidden;background:var(--hero-bg)}
.hero-wrap::before{content:'';position:absolute;inset:-40% -20%;background:radial-gradient(ellipse 60% 55% at 25% 45%,var(--hp) 0%,transparent 70%),radial-gradient(ellipse 35% 30% at 80% 65%,var(--hr) 0%,transparent 60%);filter:blur(34px);animation:gf1 14s linear infinite;z-index:0}
.hero-wrap::after{content:'';position:absolute;inset:-40% -20%;background:radial-gradient(ellipse 50% 50% at 70% 35%,var(--hb) 0%,transparent 70%),radial-gradient(ellipse 40% 45% at 50% 70%,var(--hv) 0%,transparent 65%);filter:blur(34px);animation:gf2 18s linear infinite;z-index:0}
.hero-wrap .blob{position:absolute;border-radius:50%;filter:blur(52px);z-index:0;pointer-events:none}
.hero-wrap .blob1{width:50%;height:55%;top:5%;left:2%;background:var(--hp);animation:gb1 12s linear infinite}
.hero-wrap .blob2{width:45%;height:50%;top:10%;right:2%;background:var(--hb);animation:gb2 16s linear infinite}
.hero-wrap .blob3{width:42%;height:48%;bottom:5%;left:25%;background:var(--hv);animation:gb3 20s linear infinite}
.hero-wrap .blob4{width:38%;height:42%;bottom:10%;right:10%;background:var(--hr);animation:gb4 14s linear infinite}
@keyframes gf1{0%{transform:translate(0,0) scale(1) rotate(0deg)}25%{transform:translate(-80px,60px) scale(1.12) rotate(90deg)}50%{transform:translate(70px,-50px) scale(.9) rotate(180deg)}75%{transform:translate(-50px,-70px) scale(1.08) rotate(270deg)}100%{transform:translate(0,0) scale(1) rotate(360deg)}}
@keyframes gf2{0%{transform:translate(0,0) scale(1) rotate(0deg)}25%{transform:translate(75px,-60px) scale(1.1) rotate(-90deg)}50%{transform:translate(-60px,75px) scale(1.14) rotate(-180deg)}75%{transform:translate(60px,45px) scale(.9) rotate(-270deg)}100%{transform:translate(0,0) scale(1) rotate(-360deg)}}
@keyframes gb1{0%{transform:translate(0,0) scale(1) rotate(0deg)}25%{transform:translate(100px,-80px) scale(1.25) rotate(120deg)}50%{transform:translate(-70px,100px) scale(.8) rotate(240deg)}75%{transform:translate(80px,30px) scale(1.18) rotate(300deg)}100%{transform:translate(0,0) scale(1) rotate(360deg)}}
@keyframes gb2{0%{transform:translate(0,0) scale(1) rotate(0deg)}25%{transform:translate(-90px,70px) scale(1.2) rotate(-100deg)}50%{transform:translate(80px,-90px) scale(.85) rotate(-200deg)}75%{transform:translate(-50px,-60px) scale(1.12) rotate(-300deg)}100%{transform:translate(0,0) scale(1) rotate(-360deg)}}
@keyframes gb3{0%{transform:translate(0,0) scale(1) rotate(0deg)}25%{transform:translate(85px,60px) scale(1.22) rotate(80deg)}50%{transform:translate(-100px,-40px) scale(.78) rotate(180deg)}75%{transform:translate(40px,-80px) scale(1.15) rotate(260deg)}100%{transform:translate(0,0) scale(1) rotate(360deg)}}
@keyframes gb4{0%{transform:translate(0,0) scale(1) rotate(0deg)}25%{transform:translate(-70px,-85px) scale(1.15) rotate(-110deg)}50%{transform:translate(90px,70px) scale(.82) rotate(-220deg)}75%{transform:translate(-40px,55px) scale(1.25) rotate(-310deg)}100%{transform:translate(0,0) scale(1) rotate(-360deg)}}
.hero{position:relative;z-index:1;padding:230px 48px 170px;text-align:center;max-width:780px;margin:0 auto}
.hero h1{font-family:'Plus Jakarta Sans';font-size:48px;font-weight:800;letter-spacing:-2px;line-height:1.12;margin-bottom:36px;animation:scaleIn 1s cubic-bezier(.2,.8,.3,1) both}
.search{position:relative;max-width:540px;margin:0 auto 26px;animation:fadeUp .8s ease .12s both}
.search input{width:100%;padding:15px 54px 15px 22px;border:1.5px solid var(--search-bd);border-radius:999px;font-size:16px;font-family:inherit;background:var(--search-bg);backdrop-filter:blur(12px);color:var(--text);outline:none;transition:all .3s}
.search input:focus{border-color:var(--text);box-shadow:0 0 0 3px rgba(128,128,128,.08)}
.search input::placeholder{color:var(--text2)}
.search .send-btn{position:absolute;right:8px;top:50%;transform:translateY(-50%);width:36px;height:36px;border-radius:50%;background:var(--accent);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s;flex-shrink:0}
.search .send-btn:hover{background:var(--btn-bg);transform:translateY(-50%) scale(1.06)}
.search .send-btn svg{width:18px;height:18px;stroke:#fff;fill:none}
.tags{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;animation:fadeUp .8s ease .24s both}
.tag{padding:8px 18px;border-radius:999px;border:1px solid var(--tag-bd);background:var(--tag-bg);backdrop-filter:blur(8px);font-size:12px;color:var(--text2);cursor:pointer;text-decoration:none;transition:all .3s}
.tag:hover{border-color:var(--text);color:var(--text)}

.wrap{max-width:1080px;margin:0 auto;padding:0 48px}
.sec{padding:58px 0}
.sec-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:26px}
.sec-head h2{font-size:20px;font-weight:700;letter-spacing:-.5px}
.sec-head a{font-size:12px;color:var(--text2);text-decoration:none}

.feat{display:grid;grid-template-columns:1.6fr 1fr;grid-template-rows:1fr 1fr;gap:14px}
.feat-main{grid-row:1/3;border-radius:22px;overflow:hidden;position:relative;min-height:400px;background:linear-gradient(135deg,#ff6b35,#ff3e6c,#d63384);cursor:pointer;transition:all .3s}
.feat-main:hover{transform:translateY(-3px);box-shadow:0 20px 60px rgba(0,0,0,.14)}
.feat-main .ov{position:absolute;bottom:0;left:0;right:0;padding:32px;color:#fff;background:linear-gradient(transparent,rgba(0,0,0,.5))}
.feat-main .badge{display:inline-block;padding:4px 12px;border-radius:999px;background:rgba(255,255,255,.2);backdrop-filter:blur(8px);font-size:11px;margin-bottom:8px}
.feat-main h3{font-size:24px;font-weight:700}
.feat-main p{font-size:12px;opacity:.78;margin-top:4px}
.feat-s{border-radius:22px;padding:26px;display:flex;flex-direction:column;justify-content:flex-end;color:#fff;cursor:pointer;transition:all .3s}
.feat-s:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,0,0,.12)}
.feat-s:nth-child(2){background:linear-gradient(135deg,#667eea,#764ba2)}
.feat-s:nth-child(3){background:linear-gradient(135deg,#11998e,#38ef7d)}
.feat-s h4{font-size:16px;font-weight:700}
.feat-s p{font-size:11px;opacity:.75}

.pgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.pcard{background:var(--card);border-radius:14px;padding:28px 18px;text-align:center;cursor:pointer;border:1px solid transparent;transition:all .3s}
.pcard:hover{background:var(--card2);border-color:var(--border);transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.06)}
.pcard .ico{width:68px;height:68px;margin:0 auto 14px;background:var(--icon-bg);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:26px;transition:transform .3s}
.pcard:hover .ico{transform:scale(1.08)}
.pcard h4{font-size:13px;font-weight:600;margin-bottom:5px}
.pcard .desc{font-size:11px;color:var(--text2);margin-bottom:12px}
.pcard .price{font-size:17px;font-weight:800;color:var(--accent)}

.sgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.scard{border-radius:14px;overflow:hidden;background:var(--card);cursor:pointer;border:1px solid transparent;transition:all .3s}
.scard:hover{border-color:var(--border);transform:translateY(-4px)}
.scard .thumb{height:150px}
.scard .info{padding:20px}
.scard h4{font-size:14px;font-weight:600;margin-bottom:5px}
.scard p{font-size:12px;color:var(--text2)}

.ngrid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.ncard{display:flex;gap:14px;padding:18px;border-radius:14px;cursor:pointer;border:1px solid transparent;transition:all .3s}
.ncard:hover{background:var(--card);border-color:var(--border)}
.ncard .num{font-size:32px;font-weight:900;color:var(--accent);opacity:.25;min-width:40px;line-height:1}
.ncard h4{font-size:13px;font-weight:600;line-height:1.5;margin-bottom:3px}
.ncard .date{font-size:11px;color:var(--text2)}

.crow{display:flex;border:1px solid var(--border);border-radius:22px;overflow:hidden}
.citem{flex:1;padding:34px 20px;text-align:center;border-right:1px solid var(--border);cursor:pointer;transition:background .3s}
.citem:last-child{border-right:none}
.citem:hover{background:var(--card)}
.citem .cn{font-size:18px;font-weight:700;opacity:.5;margin-bottom:6px;transition:opacity .3s}
.citem:hover .cn{opacity:1}
.citem p{font-size:11px;color:var(--text2)}

.cta{text-align:center;padding:68px 40px;margin:32px 0;background:var(--cta-bg);border-radius:22px}
.cta h2{font-size:28px;font-weight:700;letter-spacing:-1px;margin-bottom:12px}
.cta p{font-size:14px;color:var(--text2);margin-bottom:24px}
.cta .btn{padding:14px 32px;font-size:14px}

footer{border-top:1px solid var(--ft-bd);padding:40px 48px;max-width:1080px;margin:0 auto}
.fgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:28px;margin-bottom:32px}
.fgrid h5{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px}
.fgrid a{display:block;font-size:12px;color:var(--text2);text-decoration:none;margin-bottom:8px;transition:color .3s}
.fgrid a:hover{color:var(--text)}
.fbot{font-size:11px;color:var(--text2);padding-top:18px;border-top:1px solid var(--ft-bd)}

@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes scaleIn{0%{opacity:0;transform:scale(.5);filter:blur(8px)}60%{opacity:1;filter:blur(0)}100%{opacity:1;transform:scale(1);filter:blur(0)}}
.fi{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}
.fi.v{opacity:1;transform:translateY(0)}

@media(max-width:768px){
  nav{padding:0 16px;gap:8px}.nlinks{display:none}.nright a,.nright .sep,.nav-search{display:none}.nright{gap:10px}#navAuthArea{display:flex!important}#navUserArea{display:flex!important}#navAuthArea a,#navUserArea a{display:inline!important}.hero{padding:240px 20px 120px}.hero h1{font-size:30px}
  .wrap{padding:0 20px}.feat{grid-template-columns:1fr}.feat-main{grid-row:auto;min-height:250px}
  .pgrid,.sgrid,.ngrid{grid-template-columns:1fr}.crow{flex-direction:column}
  .citem{border-right:none;border-bottom:1px solid var(--border)}.fgrid{grid-template-columns:repeat(2,1fr)}
}


/* ════ PAGE SWITCHING ════ */
html,body{height:100%;overflow:hidden}
.is-chat #landingPage{display:none!important}
.is-chat #chatApp{opacity:1!important;pointer-events:all!important}
.is-chat-conv #welcomeScreen{display:none!important}
#landingPage{position:fixed;inset:0;z-index:10;background:var(--bg);overflow-y:auto;transition:opacity .4s ease,transform .4s ease}
#landingPage.exit{opacity:0;transform:scale(.97);pointer-events:none}

/* ════ CHAT APP ════ */
#chatApp{position:fixed;top:0;left:0;right:0;z-index:20;height:100vh;height:100dvh;display:flex;overflow:hidden;opacity:0;pointer-events:none;transition:opacity .35s ease}
#chatApp.active{opacity:1;pointer-events:all}
.sb-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:19;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(3px);-webkit-backdrop-filter:blur(3px)}
.sb-overlay.active{opacity:1;pointer-events:all}

/* Sidebar */
.sidebar{width:260px;flex-shrink:0;background:#fff;border-right:1px solid var(--border);display:flex;flex-direction:column;transition:width .2s}
.sb-header{padding:14px 12px 10px;border-bottom:1px solid var(--border)}
.sb-logo{display:flex;align-items:center;gap:8px;padding:8px 6px;margin-bottom:8px;cursor:pointer;font-size:17px;font-weight:700;color:#E12521;letter-spacing:-.3px;font-family:'Noto Sans SC',sans-serif}
.new-btn{width:100%;display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:#fff;color:var(--text);font-size:13px;font-family:inherit;transition:all .2s;cursor:pointer}
.new-btn:hover{background:var(--card);border-color:var(--primary)}
.new-btn svg{width:15px;height:15px;stroke:currentColor;stroke-width:2;fill:none;opacity:.7}
.sb-section{padding:14px 12px 6px;font-size:11px;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.8px}
.sb-list{flex:1;overflow-y:auto;padding:4px 8px 12px}
.sb-list::-webkit-scrollbar{width:3px}
.sb-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.conv-item{display:flex;align-items:center;gap:8px;padding:9px 10px;border-radius:9px;cursor:pointer;transition:background .15s;font-size:13px;color:var(--text2)}
.conv-item:hover{background:#F4EFFA;color:var(--text)}
.conv-item.active{background:#EBE5F2;color:var(--text)}
.conv-item svg{width:14px;height:14px;stroke:currentColor;stroke-width:1.8;fill:none;flex-shrink:0;opacity:.6}
.conv-title{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.conv-empty{padding:20px 10px;font-size:12px;color:var(--text2);text-align:center;opacity:.6}
.sb-footer{padding:12px;border-top:1px solid var(--border);display:flex;align-items:center;gap:8px}
.sb-theme-btn,.back-home-btn{display:flex;align-items:center;gap:7px;padding:8px 10px;border-radius:9px;border:none;background:transparent;color:var(--text2);font-size:12px;font-family:inherit;cursor:pointer;transition:all .2s}
.sb-theme-btn{flex:1}
.sb-theme-btn:hover,.back-home-btn:hover{background:rgba(128,128,128,.06);color:var(--text)}
.sb-theme-btn svg,.back-home-btn svg{width:14px;height:14px;stroke:currentColor;stroke-width:2;fill:none}

/* Chat main */
.chat-main{flex:1;display:flex;flex-direction:column;min-width:0;position:relative;background:#fff}
.chat-topbar{height:52px;border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px 0 24px;flex-shrink:0;gap:8px;background:#fff}
.chat-title{font-size:14px;font-weight:600;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
.topbar-btn{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:6px;border:1px solid var(--border);background:none;color:var(--text2);font-size:11px;cursor:pointer;transition:all .15s;font-family:inherit;white-space:nowrap}
.topbar-btn:hover{border-color:var(--accent);color:var(--accent)}
.topbar-btn.active{border-color:var(--accent);background:color-mix(in srgb,var(--accent) 10%,transparent);color:var(--accent)}
.menu-btn{display:none;align-items:center;justify-content:center;width:36px;height:36px;border-radius:9px;border:1px solid var(--border);background:transparent;color:var(--text);margin-right:10px;flex-shrink:0;transition:all .2s}
.menu-btn:hover{border-color:var(--accent);color:var(--accent)}
.menu-btn svg{width:16px;height:16px;stroke:currentColor;stroke-width:2;fill:none}

/* Messages */
.msgs-wrap{flex:1;overflow-y:auto;overflow-x:hidden;padding:28px 0;position:relative}
.msgs-wrap::-webkit-scrollbar{width:4px}
.msgs-wrap::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
#msgsInner{padding:0 32px;display:flex;flex-direction:column;gap:18px}

/* Welcome */
.welcome{padding:48px 32px 32px;text-align:center}
.welcome h2{font-size:clamp(22px,4vw,32px);font-weight:900;margin-bottom:10px;letter-spacing:-.03em;line-height:1.2}
.welcome h2 .grad{background:var(--primary-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-size:200%;animation:sg 4s linear infinite}
@keyframes sg{0%{background-position:0%}100%{background-position:200%}}
.welcome p{font-size:14px;color:var(--text2);margin-bottom:28px;line-height:1.7}
.wgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;text-align:left}
.wcard{background:#fff;border:1px solid var(--border);border-radius:12px;padding:14px 16px;cursor:pointer;transition:all .2s;font-size:13px;line-height:1.5;position:relative;overflow:hidden}
.wcard::after{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:var(--primary-grad);transform:scaleX(0);transition:transform .25s;transform-origin:left}
.wcard:hover{border-color:var(--primary);transform:translateY(-1px);box-shadow:0 4px 16px rgba(61,3,102,.08)}
.wcard:hover::after{transform:scaleX(1)}
.wcard strong{display:block;font-size:11px;color:var(--primary);margin-bottom:5px;font-weight:600;text-transform:uppercase;letter-spacing:.5px}

/* Msg bubbles */
.msg{display:flex;gap:10px;animation:msgIn .25s ease}
@keyframes msgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.msg.user{flex-direction:row-reverse}
.mavatar{width:32px;height:32px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700}
.msg.ai .mavatar{background:var(--primary-grad);color:#fff;font-size:11px;font-weight:700}
.msg.user .mavatar{background:var(--btn-bg);color:var(--btn-c);font-size:11px}
.mbubble{max-width:82%;padding:12px 16px;border-radius:18px;font-size:15px;line-height:30px;word-break:break-word;overflow-wrap:anywhere;min-width:0;color:var(--text)}
.msg.ai .mbubble{background:transparent;border:none;padding:0 4px;border-bottom-left-radius:0;font-size:15px;line-height:30px;color:var(--text)}
.msg.user .mbubble{background:#fff;color:var(--text);border:1.5px solid #DDD5E8;border-bottom-right-radius:4px;font-size:15px;line-height:30px}
.msg.ai .mbubble pre{font-size:13px;background:#F4EFFA;border:1px solid var(--border);padding:10px;border-radius:8px;overflow-x:auto;margin:8px 0;white-space:pre-wrap}
[data-theme="dark"] .msg.ai .mbubble pre{background:rgba(255,255,255,.05)}
.msg.ai .mbubble p{margin:0 0 8px}.msg.ai .mbubble p:last-child{margin-bottom:0}
.msg.ai .mbubble h1,.msg.ai .mbubble h2,.msg.ai .mbubble h3,.msg.ai .mbubble h4,.msg.ai .mbubble h5{font-size:16px;font-weight:700;margin:12px 0 6px;color:var(--text)}
.msg.ai .mbubble ul,.msg.ai .mbubble ol{padding-left:20px;margin:4px 0 8px}
.msg.ai .mbubble li{margin-bottom:3px}
.msg.ai .mbubble code{font-family:monospace;font-size:12px;background:#EBE5F2;color:#3D0366;padding:1px 5px;border-radius:4px}
[data-theme="dark"] .msg.ai .mbubble code{background:rgba(255,255,255,.08)}
.msg.ai .mbubble .table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin:8px 0;border-radius:8px;border:1px solid var(--border)}
.msg.ai .mbubble table{border-collapse:collapse;min-width:100%;font-size:13px}
.msg.ai .mbubble th{padding:8px 14px;text-align:left;font-size:14px;font-weight:700;background:#F4EFFA;border-bottom:1px solid var(--border);white-space:nowrap}
.msg.ai .mbubble td{padding:7px 14px;text-align:left;font-size:14px;line-height:30px;min-width:80px;border-bottom:1px solid var(--border)}
.msg.ai .mbubble tr:last-child td{border-bottom:none}
.msg.ai .mbubble a{color:var(--primary);text-decoration:underline;border-bottom:1px solid transparent;transition:border-color .15s}
.msg.ai .mbubble a:hover{border-bottom-color:var(--primary)}
.msg.ai .mbubble a.leai-ppanel-buy{color:#fff;text-decoration:none;border-bottom:none}
.streaming::after{content:'▋';display:inline-block;animation:cursorBlink .6s step-end infinite;color:var(--accent);font-size:12px;vertical-align:middle;margin-left:1px}
@keyframes cursorBlink{0%,100%{opacity:1}50%{opacity:0}}

/* Typing */
.typing-dots{display:flex;align-items:center;gap:5px;padding:12px 16px;background:var(--card);border:1px solid var(--border);border-radius:16px;border-bottom-left-radius:4px}
.tdot{width:6px;height:6px;border-radius:50%;background:var(--text2);opacity:.4;animation:td .7s ease-in-out infinite}
.tdot:nth-child(2){animation-delay:.12s}
.tdot:nth-child(3){animation-delay:.24s}
@keyframes td{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-4px);opacity:1}}

/* Suggestions */
.suggestions{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;margin-left:42px}
.suggest-chip{display:inline-flex;align-items:center;padding:6px 14px;border-radius:999px;border:1px solid var(--border);background:var(--tag-bg);color:var(--text2);font-size:12px;cursor:pointer;transition:all .2s;font-family:inherit;text-align:left;line-height:1.4}
.suggest-chip:hover{border-color:var(--primary);color:var(--primary)}

/* Input bar */
.input-bar{padding:8px 20px 10px;border-top:1px solid var(--border);flex-shrink:0;background:#fff;padding-bottom:max(10px,env(safe-area-inset-bottom))}
.input-inner{display:flex;gap:8px;align-items:flex-end}
.input-tools{display:flex;align-items:center;gap:6px;padding:6px 0 0}
.mode-pill{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:999px;border:1px solid var(--border);background:none;color:var(--text2);font-size:12px;cursor:pointer;transition:all .2s;font-family:inherit;user-select:none;white-space:nowrap}
.mode-pill svg{width:13px;height:13px;stroke:currentColor;stroke-width:2;fill:none;flex-shrink:0}
.mode-pill:hover{border-color:var(--primary);color:var(--primary)}
.mode-pill.active-web{border-color:var(--primary);color:var(--primary);background:rgba(61,3,102,.08)}
.mode-pill.active-think{border-color:var(--primary);color:var(--primary);background:rgba(61,3,102,.08)}
[data-theme="dark"] .mode-pill.active-web{border-color:#60a5fa;color:#60a5fa;background:rgba(96,165,250,.1)}
[data-theme="dark"] .mode-pill.active-think{border-color:#a78bfa;color:#a78bfa;background:rgba(167,139,250,.1)}

.msg-body{display:flex;flex-direction:column;flex:1;min-width:0}
.process-card{background:rgba(128,128,128,.06);border:1px solid var(--border);border-radius:10px;padding:8px 12px;margin-bottom:8px;font-size:12px}
.process-header{display:flex;align-items:center;gap:7px;cursor:pointer;user-select:none;color:var(--text2)}
.process-header svg{width:13px;height:13px;flex-shrink:0;stroke:currentColor;stroke-width:2;fill:none}
.process-title{flex:1;font-size:12px}
.process-steps{margin-top:6px;display:flex;flex-direction:column;gap:3px}
.process-step{display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--text2);padding:2px 0}
.process-step svg{width:13px;height:13px;flex-shrink:0;stroke:currentColor;stroke-width:2;fill:none}
.process-step.running svg{animation:spin .8s linear infinite;color:var(--accent)}
.process-step.done svg{color:#22c55e}
.process-step.fail svg{color:#ef4444}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.process-card.collapsed .process-steps{display:none}
.process-card.collapsed{background:none;border-color:transparent;padding:2px 12px}

/* Think block */
.think-block{border:1px solid color-mix(in srgb,#7c3aed 30%,var(--border));border-radius:10px;margin-bottom:8px;overflow:hidden;margin-left:42px}
[data-theme="dark"] .think-block{border-color:color-mix(in srgb,#a78bfa 30%,var(--border))}
.think-header{display:flex;align-items:center;gap:6px;padding:8px 12px;cursor:pointer;user-select:none;background:color-mix(in srgb,#7c3aed 5%,var(--bg));font-size:12px;color:#7c3aed}
[data-theme="dark"] .think-header{color:#a78bfa;background:color-mix(in srgb,#7c3aed 8%,var(--bg))}
.think-header svg{width:13px;height:13px;stroke:currentColor;stroke-width:2;fill:none;flex-shrink:0}
.think-chevron{margin-left:auto;transition:transform .2s}
.think-block.open .think-chevron{transform:rotate(180deg)}
.think-body{padding:8px 12px 10px;font-size:12px;color:var(--text2);line-height:1.7;max-height:240px;overflow-y:auto;display:none;border-top:1px solid color-mix(in srgb,#7c3aed 20%,var(--border));white-space:pre-wrap}
.think-block.open .think-body{display:block}
.think-streaming::after{content:'▋';animation:cursorBlink .6s step-end infinite;color:#7c3aed}

.ta-wrap{flex:1;border:1.5px solid var(--search-bd);border-radius:12px;background:#fff;transition:border-color .25s,box-shadow .25s;position:relative;padding:10px 14px 6px}
.ta-wrap:focus-within{border-color:var(--primary);box-shadow:0 0 0 3px rgba(61,3,102,.08)}
.ta{width:100%;resize:none;border:none;outline:none;padding:0;font-size:15px;font-family:inherit;background:transparent;color:var(--text);line-height:1.6;max-height:120px;min-height:26px}
.ta::placeholder{color:var(--text2);font-size:15px}
.send-btn{width:38px;height:38px;border-radius:50%;border:none;background:var(--send-btn-bg);color:#fff;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.send-btn:hover:not(:disabled){opacity:.85;transform:scale(1.04)}
.send-btn:disabled{background:#DDD5E8;cursor:not-allowed}
.input-hint{text-align:center;font-size:11px;color:var(--text2);opacity:.5;margin-top:7px}
.img-upload-btn{width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:none;color:var(--text2);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;flex-shrink:0}
.img-upload-btn:hover{border-color:var(--primary);color:var(--primary)}
.img-upload-btn svg{width:15px;height:15px;stroke:currentColor;stroke-width:2;fill:none}
.audio-upload-btn{width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:none;color:var(--text2);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;flex-shrink:0;font-size:14px;line-height:1}
.audio-upload-btn:hover{border-color:var(--primary);color:var(--primary)}
.img-preview-wrap{display:flex;align-items:center;gap:6px;padding:4px 8px;background:var(--search-bg);border:1px solid var(--border);border-radius:10px;margin-bottom:6px}
.img-preview-thumb{width:32px;height:32px;object-fit:cover;border-radius:6px;flex-shrink:0}
.img-preview-name{font-size:11px;color:var(--text2);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.img-preview-del{width:18px;height:18px;border:none;background:none;cursor:pointer;color:var(--text2);padding:0;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.img-preview-del:hover{color:#ef4444}
.img-preview-del svg{width:14px;height:14px;stroke:currentColor;stroke-width:2;fill:none}

/* Actions */
.msg-actions{display:flex;align-items:center;gap:2px;margin-top:4px;opacity:0;transition:opacity .15s;height:22px}
.msg.ai:hover .msg-actions,.msg.ai:focus-within .msg-actions{opacity:1}
.act-btn{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:6px;border:none;background:none;color:var(--text2);font-size:11px;cursor:pointer;transition:all .15s;font-family:inherit}
.act-btn:hover{background:rgba(128,128,128,.06);color:var(--text)}
.act-btn svg{width:11px;height:11px;stroke:currentColor;stroke-width:2;fill:none;flex-shrink:0}
.act-btn.copied{color:var(--accent)}
.act-btn.liked{color:#22c55e}
.act-btn.disliked{color:#ef4444}

/* Split compare */
.compare-wrap{display:flex;gap:12px;width:100%}
.compare-col{flex:1;min-width:0;border:1px solid var(--border);border-radius:12px;padding:10px 12px;background:var(--card)}
.compare-col .col-label{font-size:11px;font-weight:700;color:var(--text2);margin-bottom:6px;display:flex;align-items:center;gap:4px}
.compare-col .col-label .dot{width:6px;height:6px;border-radius:50%;display:inline-block}
.compare-col.self .col-label .dot{background:var(--primary)}
.compare-col.official .col-label .dot{background:#e11d48}
.compare-col .mbubble{background:transparent;border:none;padding:0;font-size:14px;line-height:28px;color:var(--text)}
.compare-col .mbubble p{margin:0 0 6px}.compare-col .mbubble p:last-child{margin-bottom:0}
.compare-col .mbubble pre{font-size:13px;background:#F4EFFA;border:1px solid var(--border);padding:8px;border-radius:8px;overflow-x:auto;white-space:pre-wrap;margin:6px 0}
[data-theme="dark"] .compare-col .mbubble pre{background:rgba(255,255,255,.05)}
.compare-col .mbubble code{font-family:monospace;font-size:12px;background:#EBE5F2;color:#3D0366;padding:1px 5px;border-radius:4px}
.compare-col .mbubble a{color:var(--primary);text-decoration:underline}
.compare-col .mbubble a.leai-ppanel-buy{color:#fff;text-decoration:none}
.compare-col .mbubble ul,.compare-col .mbubble ol{padding-left:18px;margin:4px 0 6px}
.compare-col .mbubble .table-wrap{overflow-x:auto;margin:6px 0;border-radius:8px;border:1px solid var(--border)}
.compare-col .mbubble table{border-collapse:collapse;min-width:100%;font-size:13px}
.compare-col .mbubble th{padding:6px 10px;font-weight:700;background:#F4EFFA;border-bottom:1px solid var(--border)}
.compare-col .mbubble td{padding:5px 10px;border-bottom:1px solid var(--border)}
@media(max-width:600px){.compare-wrap{flex-direction:column}.compare-col{flex:none}}

/* LeAI product cards — 完美复刻 leai.lenovo.com.cn */
.leai-products{margin-top:18px;background:linear-gradient(132deg,#ecf1ff,#fcf2f8 72%);border-radius:8px;overflow:hidden}
[data-theme="dark"] .leai-products{background:linear-gradient(132deg,#1a1a2e,#251520 72%);border:1px solid var(--border)}
.leai-ptabs{display:flex;padding:14px 16px 0;gap:22px;overflow-x:auto;scrollbar-width:none}
.leai-ptabs::-webkit-scrollbar{display:none}
.leai-ptab{padding:0 0 12px;font-size:15px;font-weight:400;color:#000;cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;transition:color .2s,font-weight .2s;flex-shrink:0;line-height:1}
.leai-ptab:hover{color:#4d144a}
.leai-ptab.active{color:#4d144a;font-weight:900;border-bottom-color:transparent}
[data-theme="dark"] .leai-ptab{color:var(--text2)}[data-theme="dark"] .leai-ptab.active{color:#e8a0c0;border-bottom-color:transparent}
.leai-pscore{width:100%;padding:6px 12px;font-size:12px;color:#6a352a;font-weight:700;display:flex;align-items:center;gap:4px}
.leai-ppanel{display:none;padding:12px 16px 14px}
.leai-ppanel.active{display:flex;gap:12px;align-items:flex-start;flex-wrap:wrap}
.leai-ppanel-img{width:142px;height:142px;object-fit:contain;flex-shrink:0;border-radius:8px}
[data-theme="dark"] .leai-ppanel-img{filter:brightness(.92)}
.leai-ppanel-info{flex:1;min-width:0;display:flex;flex-direction:column;justify-content:space-between;min-height:142px}
.leai-ppanel-name{font-size:14px;font-weight:500;color:#000;line-height:1.4;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
[data-theme="dark"] .leai-ppanel-name{color:var(--text)}
.leai-ppanel-brief{font-size:12px;color:#606060;line-height:1.7;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.leai-ppanel-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:4px}
.leai-ppanel-tag{font-size:12px;color:#ff2f2f;padding:0}
.leai-ppanel-row{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:auto}
.leai-ppanel-pricelabel{font-size:12px;color:#000}
.leai-ppanel-price{font-size:18px;font-weight:500;color:#000;font-family:-apple-system,BlinkMacSystemFont,sans-serif}
.leai-ppanel-price::before{content:'¥';font-size:14px;font-weight:500;margin-right:1px}
.leai-ppanel-buy{display:inline-flex;align-items:center;justify-content:center;width:88px;height:32px;border-radius:20px;background:linear-gradient(90deg,#6b2068 0%,#b83340 100%);color:#fff;font-size:13px;font-weight:500;text-decoration:none;transition:all .2s;border:none;letter-spacing:.5px}
.leai-ppanel-buy:hover{filter:brightness(1.1);transform:translateY(-1px);box-shadow:0 4px 12px rgba(107,32,104,.3)}
.leai-pbtns{display:flex;gap:12px;padding:10px 16px 14px}
.leai-pbtn{display:flex;align-items:center;justify-content:center;gap:4px;width:129px;height:35px;border-radius:100px;background:#f3f0f7;color:#4d144a;font-size:12px;font-weight:500;cursor:pointer;transition:all .2s;border:none}
.leai-pbtn:hover{background:#e8e0f0}
[data-theme="dark"] .leai-pbtn{background:var(--card);color:var(--text2)}
/* ── 商品弹窗 ── */
.leai-modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.45);z-index:9999;display:flex;align-items:center;justify-content:center;animation:leaiFadeIn .2s}
@keyframes leaiFadeIn{from{opacity:0}to{opacity:1}}
.leai-modal{background:#fff;border-radius:12px;width:580px;max-width:92vw;max-height:80vh;display:flex;flex-direction:column;position:relative;box-shadow:0 8px 32px rgba(0,0,0,.18)}
[data-theme="dark"] .leai-modal{background:var(--card2);box-shadow:0 8px 32px rgba(0,0,0,.5)}
.leai-modal-close{position:absolute;top:14px;right:16px;width:28px;height:28px;cursor:pointer;font-size:20px;color:#999;display:flex;align-items:center;justify-content:center;border:none;background:none;z-index:1}
.leai-modal-close:hover{color:#333}
.leai-modal-title{padding:20px 20px 0;font-size:17px;font-weight:700;color:#000}
[data-theme="dark"] .leai-modal-title{color:var(--text)}
.leai-modal-tabs{display:flex;padding:14px 20px 0;gap:22px;overflow-x:auto;scrollbar-width:none;border-bottom:1px solid #f0f0f0}
.leai-modal-tabs::-webkit-scrollbar{display:none}
.leai-modal-tab{padding:0 0 10px;font-size:14px;font-weight:400;color:#000;cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;flex-shrink:0}
.leai-modal-tab.active{color:#4d144a;font-weight:700;border-bottom-color:#4d144a}
[data-theme="dark"] .leai-modal-tabs{border-bottom-color:var(--border)}
[data-theme="dark"] .leai-modal-tab{color:var(--text2)}[data-theme="dark"] .leai-modal-tab.active{color:#e8a0c0;border-bottom-color:#e8a0c0}
.leai-modal-sorts{display:flex;gap:24px;padding:10px 20px;font-size:13px;color:#666}
.leai-modal-sort{cursor:pointer;color:#999}
.leai-modal-sort.active{color:#4d144a;font-weight:600;text-decoration:underline}
.leai-modal-body{flex:1;overflow-y:auto;padding:0 20px 16px}
.leai-modal-card{display:flex;gap:12px;padding:12px;border:1px solid #eee;border-radius:8px;margin-top:10px;cursor:pointer;transition:border-color .2s}
.leai-modal-card:hover{border-color:#4d144a}
[data-theme="dark"] .leai-modal-card{border-color:var(--border)}
.leai-modal-card img{width:80px;height:80px;object-fit:contain;flex-shrink:0;border-radius:6px}
.leai-modal-card-info{flex:1;min-width:0;display:flex;flex-direction:column;justify-content:center;gap:6px}
.leai-modal-card-name{font-size:13px;font-weight:500;color:#000;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
[data-theme="dark"] .leai-modal-card-name{color:var(--text)}
.leai-modal-card-tags{display:flex;gap:6px}
.leai-modal-card-tag{font-size:11px;padding:1px 6px;border-radius:3px}
.leai-modal-card-tag.sat{background:#e8f5e9;color:#2e7d32}
.leai-modal-card-tag.promo{background:#fff0f0;color:#ff2f2f}
[data-theme="dark"] .leai-modal-card-tag.sat{background:#1a2e1a;color:#66bb6a}
[data-theme="dark"] .leai-modal-card-tag.promo{background:#2e1a1a;color:#f87171}
.leai-modal-card-price{font-size:15px;font-weight:600;color:#000}
[data-theme="dark"] .leai-modal-card-price{color:var(--text)}
.leai-modal-foot{padding:12px 20px;border-top:1px solid #f0f0f0;display:flex;justify-content:flex-end}
