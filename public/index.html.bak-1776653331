<!-- 算术验证浮层 -->
<div id="captchaModal" style="display:none;position:fixed;inset:0;z-index:10000;align-items:center;justify-content:center;">
  <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:24px 28px;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.18);">
    <div style="font-size:22px;font-weight:700;margin-bottom:16px;" id="captchaQuestion"></div>
    <input id="captchaAnswer" type="number" placeholder="=" autofocus
      style="width:80px;padding:10px;text-align:center;border:1px solid var(--border);border-radius:8px;font-size:20px;background:var(--bg);color:var(--text);outline:none;">
    <div style="margin-top:14px;display:flex;gap:8px;justify-content:center;">
      <button onclick="submitCaptcha()" style="padding:8px 24px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-size:14px;cursor:pointer;">确认</button>
      <button onclick="closeCaptcha()" style="padding:8px 16px;background:none;border:1px solid var(--border);border-radius:8px;font-size:14px;cursor:pointer;color:var(--text2);">取消</button>
    </div>
  </div>
</div>

<script>
// ── 登录弹窗逻辑 ──
function showLoginModal(){ document.getElementById('loginModal').style.display='flex'; }
function hideLoginModal(){ document.getElementById('loginModal').style.display='none'; }
window.addEventListener('DOMContentLoaded', function(){
  var m = document.getElementById('loginModal');
  if(m) m.addEventListener('click', function(e){ if(e.target===this) hideLoginModal(); });
  // 检查登录态（_authReady 供 restoreFromUrl 等待）
  window._authReady = fetch('/api/auth/me').then(function(r){return r.json();}).then(function(d){ if(d.user) onLoginSuccess(d.user); }).catch(function(){});
});

var _captchaAnswer = 0;
var _captchaPending = false;
function refreshCaptcha(){
  var a = Math.floor(Math.random()*9)+1;
  var b = Math.floor(Math.random()*9)+1;
  _captchaAnswer = a + b;
  var el = document.getElementById('captchaQuestion');
  if(el) el.textContent = a + ' + ' + b + ' = ?';
  var inp = document.getElementById('captchaAnswer');
  if(inp){ inp.value = ''; setTimeout(function(){ inp.focus(); }, 50); }
}
function closeCaptcha(){
  document.getElementById('captchaModal').style.display='none';
  _captchaPending = false;
}
function submitCaptcha(){
  var ans = parseInt(document.getElementById('captchaAnswer').value);
  if(isNaN(ans) || ans !== _captchaAnswer){ refreshCaptcha(); return; }
  closeCaptcha();
  doSendCode();
}

async function sendLoginCode(){
  const phone = document.getElementById('loginPhone').value.trim();
  if(!/^1[3-9]\d{9}$/.test(phone)){ setLoginMsg('请输入正确的手机号'); return; }
  setLoginMsg('');
  refreshCaptcha();
  document.getElementById('captchaModal').style.display='flex';
  // 支持回车提交
  const inp = document.getElementById('captchaAnswer');
  inp.onkeydown = function(e){ if(e.key==='Enter') submitCaptcha(); };
}

async function doSendCode(){
  const phone = document.getElementById('loginPhone').value.trim();
  const btn = document.getElementById('sendCodeBtn');
  btn.disabled = true;
  try {
    const r = await fetch('/api/auth/send-code', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({phone}) });
    const d = await r.json();
    if(d.success){
      setLoginMsg('验证码已发送，请注意查收', 'green');
      let s = 60;
      btn.textContent = s + 's后重试';
      const t = setInterval(()=>{ s--; if(s<=0){ clearInterval(t); btn.disabled=false; btn.textContent='发送验证码'; } else { btn.textContent=s+'s后重试'; } }, 1000);
    } else {
      setLoginMsg(d.error || '发送失败');
      btn.disabled = false;
    }
  } catch(e){ setLoginMsg('网络错误，请重试'); btn.disabled=false; }
}

async function doLogin(){
  const phone = document.getElementById('loginPhone').value.trim();
  const code  = document.getElementById('loginCode').value.trim();
  if(!/^1[3-9]\d{9}$/.test(phone)){ setLoginMsg('请输入正确的手机号'); return; }
  if(!/^\d{6}$/.test(code)){ setLoginMsg('请输入6位验证码'); return; }
  try {
    const r = await fetch('/api/auth/login', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({phone,code,anon_uid:_UID}) });
    const d = await r.json();
    if(d.success){
      hideLoginModal();
      onLoginSuccess(d.user);
    } else {
      setLoginMsg(d.error || '登录失败');
    }
  } catch(e){ setLoginMsg('网络错误，请重试'); }
}

async function doLogout(){
  await fetch('/api/auth/logout', { method:'POST' });
  _loginUser = null;
  _anonRounds = 0;
  convList = [];
  updateSidebar();
  updateNavUser(null);
}

function updateNavUser(user){
  const authArea = document.getElementById('navAuthArea');
  const userArea = document.getElementById('navUserArea');
  const nickname = document.getElementById('navNickname');
  const chatAuth = document.getElementById('chatNavAuth');
  const chatUser = document.getElementById('chatNavUser');
  const chatNick = document.getElementById('chatNavNickname');
  const name = user ? (user.nickname || user.phone.replace(/(.{3}).+(.{4})/, '$1****$2')) : '';
  if(user){
    if(authArea) authArea.style.display = 'none';
    if(userArea) userArea.style.display = 'flex';
    if(nickname) nickname.textContent = name;
    if(chatAuth) chatAuth.style.display = 'none';
    if(chatUser) chatUser.style.display = 'block';
    if(chatNick) chatNick.textContent = name;
  } else {
    if(authArea) authArea.style.display = '';
    if(userArea) userArea.style.display = 'none';
    if(chatAuth) chatAuth.style.display = 'block';
    if(chatUser) chatUser.style.display = 'none';
  }
}

function setLoginMsg(msg, color){
  const el = document.getElementById('loginMsg');
  el.textContent = msg;
  el.style.color = color === 'green' ? '#10b981' : '#e03c31';
}


</script>
