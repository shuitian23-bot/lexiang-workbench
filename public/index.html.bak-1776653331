// 门店查询拦截：检测关键词，提取地点名
const STORE_RE = /门店|专卖店|体验店|服务站|售后.*店|维修.*点/;
const LOC_RE   = /(.{1,15}?)(?:附近|周边|旁边|那边|这边|的门店|的专卖|的联想)/;

function extractStoreLocation(msg) {
  const m = msg.match(LOC_RE);
  if (!m) return null;
  // 去掉句首的"联想""有没有""查"等虚词
  return m[1].replace(/^(联想|有没有|查询一下|查询下|查询|查一下|查下|查|帮我查|帮我找|我想查|我想找|找一下|找下|找|看看|搜索|搜一下|搜|哪里有)\s*/g, '').trim() || null;
}

async function sendMain(directMsg){
  if(!checkAnonLimit()) return;
  const ta = document.getElementById('mainTa');
  const msg = (typeof directMsg === 'string' ? directMsg : ta.value).trim();
  // 有图片或音频时允许消息为空
  const imageUrl = _pendingImageUrl;
  const audioUrl = _pendingAudioUrl;
  if (!msg && !imageUrl && !audioUrl || isLoading) return;
  ta.value = ''; ta.style.height = '';
  document.querySelectorAll('.suggestions').forEach(el => el.remove());

  // 清除图片/音频预览（已保存到局部变量）
  if (imageUrl) clearImagePreview();
  if (audioUrl) clearAudioPreview();

  // ── 门店查询拦截（仅纯文字、非对比模式时）──
  if (!leaiCompare && !imageUrl && !audioUrl && STORE_RE.test(msg)) {
    const loc = extractStoreLocation(msg);
    if (loc) {
      await findStoresByLocation(msg, loc);
      return;
    } else if (/附近|周边|旁边|我这|我在/.test(msg)) {
      // 提到"附近"但没识别到具体地名 → 走 GPS 定位
      await findNearbyStores();
      return;
    }
    // 否则（只说"门店"没说位置）→ 走普通 AI 问答
  }

  const displayMsg = msg || (audioUrl ? '请转写并分析这段音频' : '请分析这张图片');
  appendBubble('user', displayMsg);
  if(!isLoggedIn()) _anonRounds++;
  // 对比模式：仅纯文本支持，有图片/音频走普通模式
  if (leaiCompare && !imageUrl && !audioUrl) await callCompareAPI(displayMsg);
  else await callAPI(displayMsg, imageUrl, audioUrl);
}
