@media(max-width:600px){.leai-ppanel.active{flex-direction:column}.leai-ppanel-img{width:100%;height:160px}.leai-ppanel-info{min-height:auto}.leai-modal{max-width:96vw;max-height:85vh}}

/* Store cards */
.store-wrap{display:flex;flex-direction:column}
.store-intro{font-size:13px;color:var(--text2);margin-bottom:10px;line-height:1.6}
.store-card{border:1px solid var(--border);border-radius:12px;padding:12px 14px;background:var(--card);transition:border-color .2s}
.store-card+.store-card{margin-top:8px}
.store-card:hover{border-color:var(--accent)}
.store-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
.store-name{font-size:14px;font-weight:600;color:var(--text);line-height:1.4}
.store-dist{font-size:12px;font-weight:700;color:var(--accent);white-space:nowrap;flex-shrink:0}
.store-addr{font-size:12px;color:var(--text2);margin-top:4px;line-height:1.5}
.store-footer{display:flex;align-items:center;flex-wrap:wrap;gap:0;margin-top:6px}
.store-tel{display:inline-flex;align-items:center;gap:4px;font-size:11.5px;color:var(--text2)}
.store-tel svg,.store-nav svg{width:11px;height:11px;stroke:currentColor;stroke-width:2;fill:none;flex-shrink:0}
.store-sep{color:var(--border);margin:0 8px;font-size:11px}
