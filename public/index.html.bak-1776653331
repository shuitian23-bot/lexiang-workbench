// ── 按地点名搜门店（地理编码 → 周边搜索） ──
async function findStoresByLocation(origMsg, locName) {
  showChatApp();
  appendBubble('user', origMsg);
  const bubbleEl = appendBubble('ai', '');
  const mbubble = bubbleEl.querySelector('.mbubble');
  mbubble.textContent = `🔍 正在定位"${locName}"…`;

  try {
    const geoRes = await apiFetch(`/api/stores/geocode?address=${encodeURIComponent(locName)}`);
    const geo = await geoRes.json();
    if (geo.error) { mbubble.textContent = geo.error; return; }

    mbubble.textContent = '🏪 正在搜索附近联想门店…';
    const storeRes = await apiFetch(`/api/stores/nearby?lat=${geo.lat}&lng=${geo.lng}`);
    const result = await storeRes.json();
    if (result.error) { mbubble.textContent = result.error; return; }

    renderStoreCards(mbubble, result.stores || [], geo.lat, geo.lng, geo.name);
  } catch (e) {
    mbubble.textContent = '搜索失败，请稍后重试。';
  }
}

// ── 门店查询（GPS 定位 + 百度POI） ──
async function findNearbyStores() {
  showChatApp();
  const userBubble = appendBubble('user', '查询附近联想门店');
  const bubbleEl = appendBubble('ai', '');
  const mbubble = bubbleEl.querySelector('.mbubble');
  mbubble.textContent = '📍 正在获取您的位置…';

  if (!navigator.geolocation) {
    // 降级：走 AI 问答
    userBubble.remove(); bubbleEl.remove();
    await startChat('我想查询附近的联想门店，请问如何找到最近的线下服务中心或体验店？');
    return;
  }

  let position;
  try {
    position = await new Promise((resolve, reject) =>
      navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 20000, enableHighAccuracy: false })
    );
  } catch (err) {
    // 拒绝授权或超时 → 降级走 AI 问答
    userBubble.remove(); bubbleEl.remove();
    await startChat('我想查询附近的联想门店，请问如何找到最近的线下服务中心或体验店？');
    return;
  }

  const { latitude: lat, longitude: lng } = position.coords;
  mbubble.textContent = '🔍 正在搜索附近门店…';

  let result;
  try {
    const res = await apiFetch(`/api/stores/nearby?lat=${lat}&lng=${lng}`);
    result = await res.json();
  } catch (e) {
    mbubble.textContent = '搜索失败，请稍后重试。';
    return;
  }

  if (result.error) {
    mbubble.textContent = result.hint || result.error;
    return;
  }

  const stores = result.stores || [];
  renderStoreCards(mbubble, stores, lat, lng);
}

function distText(m) {
  return m < 1000 ? m + ' m' : (m / 1000).toFixed(1) + ' km';
}

