        buf = lines.pop();
        for (const line of lines) {
          if (line.startsWith('event: ')) { lastEvent = line.slice(7).trim(); continue; }
          if (line === '') { lastEvent = ''; continue; }
          if (!line.startsWith('data: ')) continue;
          let d; try { d = JSON.parse(line.slice(6)); } catch { continue; }
          if ((lastEvent === 'chunk' || (!lastEvent && d.text)) && d.text) {
            selfQueue.push(d.text);
          } else if (lastEvent === 'products' && d.products?.length) {
