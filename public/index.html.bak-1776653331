    } catch(e) { selfQueue.push('网络错误'); }
    selfStreamDone = true;
  })();

  // ── 官方AI流 ──
  let officialProducts = [];
  const officialStream = (async () => {
    try {
      // 获取 token
      if (!leaiSession.token) {
        const r = await fetch('/api/leai/auth');
        const d = await r.json();
        if (d.rc === 0 && d.data) { leaiSession.token = d.data.token; leaiSession.sessionId = d.data.sessionId; }
        else { officialBubble.textContent = '官方AI认证失败'; officialBubble.classList.remove('streaming'); return; }
      }
      const res = await fetch('/api/leai/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId: leaiSession.sessionId, token: leaiSession.token, input: msg })
      });
      if (!res.ok) { officialBubble.textContent = '官方AI请求失败'; officialBubble.classList.remove('streaming'); return; }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buf = '', lastEvent = '';
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        const lines = buf.split('\n');
        buf = lines.pop();
        for (const line of lines) {
          if (line.startsWith('event:')) { lastEvent = line.slice(6).trim(); continue; }
          if (line === '') { lastEvent = ''; continue; }
          if (!line.startsWith('data:')) continue;
          const raw = line.slice(5);
          if (lastEvent === 'thinking_trace') continue;
          if (lastEvent === 'timeout') { officialAccum += '\n（超时）'; continue; }
          try {
            const d = JSON.parse(raw);
            const rt = d.response?.response_text || d.response_text;
            if (rt) { officialAccum = rt; console.log('[LeAI] got text, len:', rt.length, 'event:', lastEvent); }
            // 提取商品卡片数据
            const pl = d.response?.product_list || d.product_list;
            if (pl?.length) officialProducts = pl;
          } catch(pe) { console.warn('[LeAI] parse error:', pe.message, 'raw:', raw.slice(0, 80)); }
          renderOfficial();
        }
      }
    } catch(e) { console.error('[LeAI] stream error:', e); officialAccum = '连接失败'; }
    // token可能过期，清空重试一次
    if (!officialAccum && leaiSession.token) {
      console.log('[LeAI] empty response, retrying with fresh token...');
      leaiSession.token = null; leaiSession.sessionId = null;
      try {
        const r2 = await fetch('/api/leai/auth');
        const d2 = await r2.json();
        if (d2.rc === 0 && d2.data) {
          leaiSession.token = d2.data.token; leaiSession.sessionId = d2.data.sessionId;
          const res2 = await fetch('/api/leai/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sessionId: leaiSession.sessionId, token: leaiSession.token, input: msg }) });
          if (res2.ok) {
            const reader2 = res2.body.getReader();
            const decoder2 = new TextDecoder();
            let buf2 = '', lastEvent2 = '';
            while (true) {
              const { done, value } = await reader2.read();
              if (done) break;
              buf2 += decoder2.decode(value, { stream: true });
              const lines2 = buf2.split('\n');
              buf2 = lines2.pop();
              for (const line of lines2) {
                if (line.startsWith('event:')) { lastEvent2 = line.slice(6).trim(); continue; }
                if (line === '') { lastEvent2 = ''; continue; }
                if (!line.startsWith('data:')) continue;
                if (lastEvent2 === 'thinking_trace') continue;
                try {
                  const d = JSON.parse(line.slice(5));
                  const rt = d.response?.response_text || d.response_text;
                  if (rt) { officialAccum = rt; }
                  const pl = d.response?.product_list || d.product_list;
                  if (pl?.length) officialProducts = pl;
                } catch {}
                renderOfficial();
              }
            }
          }
        }
      } catch(e2) { console.error('[LeAI] retry failed:', e2); }
    }
    officialBubble.classList.remove('streaming');
    officialBubble.innerHTML = renderMdText(officialAccum || '（无回复）');
    // 渲染商品卡片
    console.log('[LeAI] products found:', officialProducts.length);
    if (officialProducts.length) {
      const cardsHtml = renderLeaiProducts(officialProducts);
      console.log('[LeAI] cards HTML length:', cardsHtml.length);
      officialBubble.insertAdjacentHTML('beforeend', cardsHtml);
    }
  })();

  await Promise.all([selfStream, officialStream]);
  _log.event('compare_reply', { ms: Date.now()-t0, convId });
  // 保存官方AI回复到DB
  if (selfMsgId && officialAccum) {
    apiFetch('/api/chat/messages/' + selfMsgId + '/leai', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ leai_text: officialAccum, leai_products: officialProducts })
    }).catch(() => {});
  }
  } finally {
    isLoading = false;
    document.getElementById('mainSend').disabled = false;
  }
}

