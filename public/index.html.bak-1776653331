// ── Send to API (streaming) ──
async function callAPI(msg, imageUrl, audioUrl){
  const t0 = Date.now();
  isLoading = true;
  document.getElementById('mainSend').disabled = true;

  // 立即创建 AI 气泡
  const bubbleEl = appendBubble('ai', '');
  const preEl = bubbleEl.querySelector('.msg-pre');
  const stream = startStream(bubbleEl);

  // 创建 process card
  const procCard = createProcessCard();
  preEl.appendChild(procCard);
  let procStep = 0; // 递增 ID，避免冲突
  let thinkBlock = null;
  let thinkBody = null;
  let thinkAccum = '';
  let firstChunk = true;

  try {
    const bodyData = { message: msg, conv_id: convId, web_search: webSearchEnabled, lang: currentLang, thinking_mode: thinkingEnabled };
    if (imageUrl) bodyData.image_url = imageUrl;
    if (audioUrl) bodyData.audio_url = audioUrl;
    const res = await apiFetch('/api/chat/stream', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(bodyData)
    });

    if (!res.ok) {
      const errMap = {429:'请求太频繁，请稍后再试',500:'服务器暂时不可用',502:'服务器维护中',503:'服务繁忙'};
      const err = await res.json().catch(() => ({}));
      const friendly = errMap[res.status] || err.error || '服务暂时不可用，请稍后重试';
      preEl.remove();
      stream.finish();
      bubbleEl.querySelector('.mbubble').textContent = '抱歉，' + friendly;
      return;
    }

    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buf = '';
    let lastEvent = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buf += decoder.decode(value, { stream: true });
      const lines = buf.split('\n');
      buf = lines.pop();

      for (const line of lines) {
        if (line.startsWith('event: ')) { lastEvent = line.slice(7).trim(); continue; }
        if (line === '') { lastEvent = ''; continue; }
        if (!line.startsWith('data: ')) continue;
        let d;
        try { d = JSON.parse(line.slice(6)); } catch { console.warn('Stream parse error:', line); continue; }

        if (lastEvent === 'status') {
          if (d.type === 'rag') {
            addProcessStep(procCard, 'rag', d.text);
          } else if (d.type === 'rag_done') {
            doneProcessStep(procCard, 'rag', true);
          } else if (d.type === 'tool') {
            const sid = 'tool-' + (++procStep);
            addProcessStep(procCard, sid, toolLabel(d.name));
            procCard._lastToolId = sid;
          } else if (d.type === 'tool_done') {
            if (procCard._lastToolId) doneProcessStep(procCard, procCard._lastToolId, d.success !== false);
          }
        }

        else if (lastEvent === 'thinking') {
          if (!thinkBlock) {
            thinkBlock = createThinkBlock();
            preEl.appendChild(thinkBlock);
            thinkBody = thinkBlock.querySelector('.think-body');
          }
          thinkAccum += d.text;
          thinkBody.textContent = thinkAccum;
          scrollBottom();
        }

        else if (lastEvent === 'think_end') {
          if (thinkBlock) finalizeThinkBlock(thinkBlock);
        }

        else if (lastEvent === 'chunk' || (!lastEvent && d.text)) {
          if (d.text) {
            if (firstChunk) {
              firstChunk = false;
              collapseProcessCard(procCard);
            }
            stream.push(d.text);
          }
        }

        else if (lastEvent === 'done') {
          if (d.convId) {
            convId = d.convId;
            document.getElementById('shareBtn').style.display = '';
          }
          stream.finish();
          _log.event('chat_reply', { ms: Date.now()-t0, convId });
          if (convId) history.replaceState(null, '', '/chat/' + convId);
          loadConvList();
        }

        else if (lastEvent === 'products') {
          if (d.products?.length) {
            const cardsHtml = renderSelfProducts(d.products);
            if (cardsHtml) bubbleEl.querySelector('.mbubble').insertAdjacentHTML('beforeend', cardsHtml);
            scrollBottom();
          }
        }

        else if (lastEvent === 'suggestions') {
          if (d.suggestions?.length) renderSuggestions(bubbleEl, d.suggestions);
        }

        else if (lastEvent === 'error') {
          stream.finish();
          bubbleEl.querySelector('.mbubble').textContent = '抱歉，出了点问题：' + (d.message || '未知错误');
        }
      }
    }

  } catch(e) {
    _log.error('callAPI stream error', e.stack, { msg: msg.slice(0,80) });
    stream.finish();
    bubbleEl.querySelector('.mbubble').textContent = '网络错误，请稍后重试。';
  } finally {
    isLoading = false;
    document.getElementById('mainSend').disabled = false;
  }
}

